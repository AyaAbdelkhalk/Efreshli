            <script>

                                function showConfirmationModal(options) {
                    const modal = $('#confirmationModal');

                    // Set dynamic content
                    if (options.message) {
                        modal.find('.modal-body').html(options.message);
                    }

                    // Set form action
                    modal.find('form').attr('action', options.formAction);

                    // Set item ID
                    modal.find('input[name="id"]').val(options.itemId);

                    // Change modal color based on action type
                    if (options.actionType === 'delete') {
                        modal.find('.modal-header').removeClass('bg-warning bg-primary').addClass('bg-danger');
                    } else if (options.actionType === 'warning') {
                        modal.find('.modal-header').removeClass('bg-danger bg-primary').addClass('bg-warning');
                    }

                    modal.modal('show');
                }

                // Data attributes initialization
                $(document).on('click', '[data-toggle="confirm-modal"]', function() {
                    const $el = $(this);
                    showConfirmationModal({
                        formAction: $el.data('form-action'),
                        itemId: $el.data('item-id'),
                        actionType: $el.data('action-type'),
                        message: $el.data('message')
                    });
                });
                     document.addEventListener("DOMContentLoaded", function () {
            const match = document.cookie.match(/LanguagePreference=([^;]+)/);
                if (match) {
                    const culture = match[1].split('|')[0].split('=')[1];
                    document.getElementById("languageSelect").value = culture;
                }
             });
                function setLanguage(culture) {
                     document.cookie = `LanguagePreference=c=${culture}|uic=${culture}; path=/`;
                     location.reload(); // إعادة تحميل الصفحة
             }
    </script>
