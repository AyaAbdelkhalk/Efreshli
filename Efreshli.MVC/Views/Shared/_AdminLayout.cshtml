<!-- #endregion -->
    <script>tailwind.config = { theme: { extend: { colors: { primary: '#fc0000e5', secondary: '#6366f1', accent: '#f1f5f9', dark: '#1e293b' }, borderRadius: { 'none': '0px', 'sm': '4px', DEFAULT: '8px', 'md': '12px', 'lg': '16px', 'xl': '20px', '2xl': '24px', '3xl': '28px', 'full': '9999px', 'button': '8px' }, animation: { float: 'float 3s ease-in-out infinite', glow: 'glow 2s ease-in-out infinite alternate', slideIn: 'slideIn 0.5s ease-out' }, fontFamily: { sans: ['Inter', 'system-ui', 'sans-serif'], display: ['Inter', 'system-ui', 'sans-serif'] } } } }</script>
    <style>
        .sidebar-language {
            margin: 15px;
            color: white;
            font-size: 14px;
        }

            .sidebar-language label {
                display: block;
                margin-bottom: 5px;
                font-weight: bold;
            }

            .sidebar-language select {
                width: 100%;
