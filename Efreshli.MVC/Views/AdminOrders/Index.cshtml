@using Efreshli.Domain.Enums
@model Efreshli.MVC.Models.ViewModels.AdminOrderListViewModel

@{
    ViewData["Title"] = "Orders Management";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary">Orders Management</h2>
    </div>

    <!-- Filters Section -->
    <div class="card shadow-sm mb-4 rounded-3">
        <div class="card-body">
            <form method="get" class="row g-3">
                <div class="col-md-3">
                    <label for="searchTerm" class="form-label">Search</label>
                    <input type="text" class="form-control" id="searchTerm" name="Filters.SearchTerm" 
                           placeholder="Order ID or Customer Phone" 
                           value="@Model.Filters.SearchTerm">
                </div>
                
                <div class="col-md-2">
                    <label for="status" class="form-label">Status</label>
                    <select class="form-select" id="status" name="Filters.Status">
                        <option value="">All Statuses</option>
                        <option value="@OrderStatus.Pending" selected="@(Model.Filters.Status == OrderStatus.Pending)">Pending</option>
                        <option value="@OrderStatus.Processing" selected="@(Model.Filters.Status == OrderStatus.Processing)">Processing</option>
                        <option value="@OrderStatus.Shipped" selected="@(Model.Filters.Status == OrderStatus.Shipped)">Shipped</option>
                        <option value="@OrderStatus.Delivered" selected="@(Model.Filters.Status == OrderStatus.Delivered)">Delivered</option>
                        <option value="@OrderStatus.Cancelled" selected="@(Model.Filters.Status == OrderStatus.Cancelled)">Cancelled</option>
                    </select>
                </div>
                
                <div class="col-md-2">
                    <label for="paymentMethod" class="form-label">Payment Method</label>
                    <select class="form-select" id="paymentMethod" name="Filters.PaymentMethod">
                        <option value="">All Methods</option>
                        <option value="@PaymentMethod.CashOnDelivery" selected="@(Model.Filters.PaymentMethod == PaymentMethod.CashOnDelivery)">Cash</option>
                        <option value="@PaymentMethod.Stripe" selected="@(Model.Filters.PaymentMethod == PaymentMethod.Stripe)">Online</option>
                    </select>
                </div>
                
                <div class="col-md-2">
                    <label for="shippingType" class="form-label">Shipping Type</label>
                    <select class="form-select" id="shippingType" name="Filters.ShippingType">
                        <option value="">All Types</option>
                        <option value="Delivery" selected="@(Model.Filters.ShippingType == "Delivery")">Delivery</option>
                        <option value="Pickup" selected="@(Model.Filters.ShippingType == "Pickup")">Pickup</option>
                    </select>
                </div>
                
                <div class="col-md-2">
                    <label for="dateFrom" class="form-label">Date From</label>
                    <input type="date" class="form-control" id="dateFrom" name="Filters.DateFrom" 
                           value="@(Model.Filters.DateFrom?.ToString("yyyy-MM-dd"))">
                </div>
                <div class="col-md-2">
                    <label for="dateTo" class="form-label">Date To</label>
                    <input type="date" class="form-control" id="dateTo" name="Filters.DateTo" 
                           value="@(Model.Filters.DateTo?.ToString("yyyy-MM-dd"))">
                </div>
                <div class="col-md-1 d-flex align-items-end">
                    <div class="btn-group" role="group">
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-filter"></i> Apply
                        </button>
                    </div>
                </div>
                <div class="col-md-1 d-flex align-items-end">
                    <a href="@Url.Action("Index")" class="btn btn-outline-secondary">
                        <i class="fas fa-undo"></i> Reset
                    </a>
                </div>
            </form>
        </div>
    </div>

    <!-- Orders Table -->
    <div class="card shadow-sm rounded-3">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Order ID</th>
                            <th>Customer</th>
                            <th>Phone</th>
                            <th>Date</th>
                            <th>Total</th>
                            <th>Payment</th>
                            <th>Shipping</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Orders.Any())
                        {
                            @foreach (var order in Model.Orders)
                            {
                                <tr>
                                    <td><strong>#@order.OrderId</strong></td>
                                    <td>@order.CustomerName</td>
                                    <td>@(string.IsNullOrEmpty(order.CustomerPhone) ? "N/A" : order.CustomerPhone)</td>
                                    <td>@order.CreatedAt.ToString("MMM dd, yyyy")</td>
                                    <td>@order.TotalPrice.ToString("C")</td>
                                    <td>
                                        @if (order.PaymentMethod == PaymentMethod.CashOnDelivery)
                                        {
                                            <span class="badge bg-warning-subtle text-warning-emphasis">Cash</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success-subtle text-success-emphasis">Online</span>
                                        }
                                    </td>
                                    <td>
                                        @if (order.ShippingType == "Delivery")
                                        {
                                            <span class="badge bg-info-subtle text-info-emphasis">Delivery</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-primary-subtle text-primary-emphasis">Pickup</span>
                                        }
                                    </td>
                                    <td>
                                        @switch (order.Status)
                                        {
                                            case OrderStatus.Pending:
                                                <span class="badge rounded-pill bg-warning">Pending</span>
                                                break;
                                            case OrderStatus.Processing:
                                                <span class="badge rounded-pill bg-primary">Processing</span>
                                                break;
                                            case OrderStatus.Shipped:
                                                <span class="badge rounded-pill bg-purple">Shipped</span>
                                                break;
                                            case OrderStatus.Delivered:
                                                <span class="badge rounded-pill bg-success">Delivered</span>
                                                break;
                                            case OrderStatus.Cancelled:
                                                <span class="badge rounded-pill bg-danger">Cancelled</span>
                                                break;
                                        }
                                    </td>
                                    <td>
                                        <a href="@Url.Action("Details", new { id = order.OrderId })" 
                                           class="btn btn-sm btn-outline-primary">
                                            <i class="fas fa-eye"></i> View Details
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="9" class="text-center py-5">
                                    <i class="fas fa-inbox fa-2x text-muted mb-3"></i>
                                    <h5 class="text-muted">No orders found</h5>
                                    <p class="text-muted">Try adjusting your filters or check back later</p>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            
            <!-- Pagination (if needed) -->
            @if (Model.Orders.Any())
            {
                <div class="d-flex justify-content-between align-items-center mt-4">
                    <div class="text-muted">
                        Showing @Model.Orders.Count() of @Model.Orders.Count() orders
                    </div>
                    <!-- Add pagination controls here if needed -->
                </div>
            }
        </div>
    </div>
</div>

<style>
    .bg-purple {
        background-color: #6f42c1 !important;
    }
    
    .badge.rounded-pill {
        font-size: 0.75em;
        padding: 0.5em 0.8em;
    }
    
    .table th {
        font-weight: 600;
    }
    
    .card {
        border: none;
    }
</style>