@model Efreshli.Application.DTOs.CouponDTOs.UpdateCouponDTO
<link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css">
@{
    var pageTitle = _stringLocalizer[SharedResourcesKeys.Title.EditItem, _stringLocalizer[SharedResourcesKeys.Efreshli.Coupon.Title]];
    ViewBag.Title = pageTitle;
}

<div class="container">
    <div class="form-container bg-white p-4 rounded shadow-sm">
        <form asp-action="Edit" asp-controller="Coupon" method="post" id="couponForm" novalidate>
            @Html.AntiForgeryToken()

            <!-- Hidden CouponId Field -->
            <input type="hidden" asp-for="CouponId" />

            <!-- Validation Summary -->
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <!-- Code Field -->
            <div class="mb-3">
                <label asp-for="Code" class="form-label" for="Code">
                    @_stringLocalizer[SharedResourcesKeys.Efreshli.Coupon.Code]
                </label>
                <input asp-for="Code" class="form-control" id="Code" placeholder="SUMMER20" minlength="4" maxlength="20" />
                <span asp-validation-for="Code" class="text-danger"></span>
            </div>

            <!-- Discount Value Field -->
            <div class="mb-3">
                <label asp-for="DiscountValue" class="form-label" for="DiscountValue">
                    @_stringLocalizer[SharedResourcesKeys.Efreshli.Coupon.DiscountValue]
                </label>
                <div class="input-group">
                    <input asp-for="DiscountValue" class="form-control" id="DiscountValue" placeholder="10" type="number" min="0" step="0.01" />
                    <span class="input-group-text" id="discountSuffix" data-currency="@_stringLocalizer[SharedResourcesKeys.Currency.EGP]">$</span>
                </div>
                <span asp-validation-for="DiscountValue" class="text-danger"></span>
            </div>

            <!-- Discount Type Toggle -->
            <div class="mb-3">
                <input type="radio" class="btn-check" asp-for="IsPercentage" id="fixedAmount" value="false" checked="@(!Model.IsPercentage)" />
                <label class="btn btn-outline-primary" for="fixedAmount">
                    @_stringLocalizer[SharedResourcesKeys.Efreshli.Coupon.FixedAmount]
                </label>

                <input type="radio" class="btn-check" asp-for="IsPercentage" id="percentage" value="true" checked="@(Model.IsPercentage)" />
                <label class="btn btn-outline-primary" for="percentage">
                    @_stringLocalizer[SharedResourcesKeys.Efreshli.Coupon.IsPercentage]
                </label>
            </div>
            <!-- Minimum Order Amount -->
            <div class="mb-3">
                <label asp-for="MinOrderAmount" class="form-label" for="MinOrderAmount">
                    @_stringLocalizer[SharedResourcesKeys.Efreshli.Coupon.MinOrderAmount]
                </label>
                <div class="input-group">
                    <input asp-for="MinOrderAmount" class="form-control" id="MinOrderAmount" type="number" min="0" step="0.01" placeholder="0 for no minimum" />
                    <span class="input-group-text">@_stringLocalizer[SharedResourcesKeys.Currency.EGP]</span>
                </div>
                <span asp-validation-for="MinOrderAmount" class="text-danger"></span>
            </div>
            <!-- Usage Limit -->
            <div class="mb-3">
                <label asp-for="UsageLimit" class="form-label" for="UsageLimit">
                    @_stringLocalizer[SharedResourcesKeys.Efreshli.Coupon.UsageLimit]
                </label>
                <input asp-for="UsageLimit" class="form-control" id="UsageLimit" type="number" min="0" placeholder="0 for unlimited" />
                <span asp-validation-for="UsageLimit" class="text-danger"></span>
            </div>
            <!-- Expiration Date -->
            <div class="mb-3">
                <label asp-for="ExpireDate" class="form-label" for="ExpireDate">
                    @_stringLocalizer[SharedResourcesKeys.Efreshli.Coupon.ExpireDate]
                </label>
                <input asp-for="ExpireDate" class="form-control" id="ExpireDate" type="datetime-local"
                       value="@DateTime.UtcNow.ToString("yyyy-MM-ddTHH:mm")"
                       min="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" />
                <span asp-validation-for="ExpireDate" class="text-danger"></span>
            </div>
            <!-- Actions -->
            <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                <a asp-action="Index" class="btn btn-secondary me-md-2">
                    @_stringLocalizer[SharedResourcesKeys.Actions.Cancel]
                </a>
                <button type="submit" class="btn btn-primary">
                    @_stringLocalizer[SharedResourcesKeys.Actions.Update]
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const form = document.getElementById('couponForm');
            const discountSuffix = document.getElementById('discountSuffix');
            const discountValueInput = document.getElementById('DiscountValue');

            const updateDisplay = () => {
                const isPercentage = form.querySelector('input[name="IsPercentage"]:checked').value === 'true';
                discountSuffix.textContent = isPercentage ? '%' : discountSuffix.dataset.currency;

                if (isPercentage) {
                    discountValueInput.placeholder = 'e.g., 20 (for 20%)';
                    discountValueInput.max = 100;
                } else {
                    discountValueInput.placeholder = 'e.g., 10';
                    discountValueInput.removeAttribute('max');
                }
            };

            // Auto-uppercase coupon code
            document.getElementById('Code').addEventListener('input', function() {
                this.value = this.value.toUpperCase();
            });

            // Update display when discount type changes
            form.querySelectorAll('input[name="IsPercentage"]').forEach(radio => {
                radio.addEventListener('change', updateDisplay);
            });

            // Initialize display
            updateDisplay();
        });
    </script>
}