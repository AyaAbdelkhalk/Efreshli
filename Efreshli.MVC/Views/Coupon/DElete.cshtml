@using Efreshli.Application.Resources
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResources> Localizer
@model Efreshli.Application.DTOs.CouponDTOs.CouponDTO
@* <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"> *@
<div class="container mx-auto px-4 py-8">
    <div class="bg-white rounded-xl shadow-md overflow-hidden p-6 max-w-2xl mx-auto">
        <h2 class="text-2xl font-bold text-gray-800 mb-6">@Localizer[SharedResourcesKeys.Confirm.Delete]</h2>

        <div class="space-y-4">
            <div class="bg-red-50 border-l-4 border-red-400 p-4 rounded-lg">
                <div class="flex">
                    <div class="flex-shrink-0">
                        <svg class="h-5 w-5 text-red-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
                        </svg>
                    </div>
                    <div class="ml-3">
                        <h3 class="text-lg font-medium text-red-800">@Localizer[SharedResourcesKeys.Actions.Delete]</h3>
                        <p class="mt-2 text-red-600">@Localizer[SharedResourcesKeys.Confirm.Delete]</p>
                    </div>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <dt class="text-sm font-medium text-gray-500">@Localizer["Coupon.Fields.Code"]</dt>
                    <dd class="mt-1 text-sm text-gray-900 font-mono bg-gray-50 p-2 rounded">@Model.Code</dd>
                </div>
                <div>
                    <dt class="text-sm font-medium text-gray-500">@Localizer["Coupon.Fields.DiscountValue"]</dt>
                    <dd class="mt-1 text-sm text-gray-900 bg-gray-50 p-2 rounded">
                        @Model.DiscountValue.ToString("0.##") @(Model.IsPercentage? Localizer["General.PercentSymbol"] : Localizer["Currency.EGP"])
                    </dd>
                </div>
                @* @if (Model.ExpiryDate.HasValue)
                {
                    <div>
                        <dt class="text-sm font-medium text-gray-500">@Localizer["Coupon.Fields.ExpiryDate"]</dt>
                        <dd class="mt-1 text-sm text-gray-900 bg-gray-50 p-2 rounded">
                            @Model.ExpiryDate.Value.ToString("d")
                        </dd>
                    </div>
                }
                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    <div class="md:col-span-2">
                        <dt class="text-sm font-medium text-gray-500">@Localizer["Coupon.Fields.Description"]</dt>
                        <dd class="mt-1 text-sm text-gray-900 bg-gray-50 p-2 rounded">
                            @Model.Description
                        </dd>
                    </div>
                } *@
            </div>

            <form asp-action="Delete" method="post" class="pt-4 border-t border-gray-200">
                <input type="hidden" asp-for="CouponId" />
                @Html.AntiForgeryToken()

                <div class="flex justify-end space-x-3">
                    <a asp-action="Index" class="inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary">
                        @Localizer[SharedResourcesKeys.Actions.Cancel]
                    </a>
                    <button type="submit" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-red-600 hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500">
                        <svg class="-ml-1 mr-2 h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                            <path fill-rule="evenodd" d="M9 2a1 1 0 00-.894.553L7.382 4H4a1 1 0 000 2v10a2 2 0 002 2h8a2 2 0 002-2V6a1 1 0 100-2h-3.382l-.724-1.447A1 1 0 0011 2H9zM7 8a1 1 0 012 0v6a1 1 0 11-2 0V8zm5-1a1 1 0 00-1 1v6a1 1 0 102 0V8a1 1 0 00-1-1z" clip-rule="evenodd" />
                        </svg>
                        @Localizer[SharedResourcesKeys.Actions.Delete]
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
<div>
   
</div>







