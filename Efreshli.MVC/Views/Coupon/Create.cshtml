@model Efreshli.Application.DTOs.CouponDTOs.AddCouponDTO

@{
    var pageTitle = _stringLocalizer[SharedResourcesKeys.Title.CreateItem, _stringLocalizer[SharedResourcesKeys.Efreshli.Coupon.Title]];
    ViewBag.Title = pageTitle;
}

<style>
    body {
        background: #f8f9fa;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    /* Container full width */
    .container {
        width: 100%;
        max-width: 100%;
        margin: 0 auto;
        padding: 20px;
    }

    /* Form box full width */
    .form-container {
        width: 100%;
        background: #fff;
        padding: 25px;
        border-radius: 8px;
        box-shadow: 0 3px 10px rgba(0,0,0,0.1);
    }

    .form-label {
        display: block;
        font-weight: 600;
        margin-bottom: 5px;
    }

    .form-control {
        width: 100%;
        padding: 10px 12px;
        border: 1px solid #ccc;
        border-radius: 6px;
        outline: none;
        transition: border 0.2s;
    }

        .form-control:focus {
            border-color: #dc3545;
            box-shadow: 0 0 4px rgba(13,110,253,0.3);
        }

    .mb-3 {
        margin-bottom: 18px;
    }

    .text-danger {
        color: #dc3545;
        font-size: 0.9em;
    }

    .input-group {
        display: flex;
        align-items: stretch;
    }

        .input-group .form-control {
            flex: 1;
            border-top-right-radius: 0;
            border-bottom-right-radius: 0;
        }

    .input-group-text {
        background: #f1f1f1;
        padding: 10px 15px;
        border: 1px solid #ccc;
        border-left: none;
        border-radius: 0 6px 6px 0;
        font-weight: 500;
        color: #333;
    }

    /* Toggle buttons */
    .btn-toggle {
        display: inline-block;
        padding: 8px 14px;
        border: 1px solid #dc3545;
        border-radius: 6px;
        background: #fff;
        color: #dc3545;
        font-weight: 500;
        cursor: pointer;
        margin-right: 8px;
        transition: 0.2s;
    }

        .btn-toggle:hover {
            background: #e11d48;
            color: #fff;
        }

    input[type="radio"] {
        display: none;
    }

        input[type="radio"]:checked + .btn-toggle {
            background: #dc3545;
            color: #fff;
        }

    /* Buttons */
    .form-actions {
        display: flex;
        justify-content: flex-end;
        gap: 10px;
    }

    .btn {
        padding: 10px 18px;
        border-radius: 6px;
        border: none;
        font-weight: 600;
        cursor: pointer;
        transition: background 0.2s;
    }

    .btn-primary {
        background: #dc3545;
        color: #fff;
    }

        .btn-primary:hover {
            background: #e11d48;
        }

    .btn-secondary {
        background: #6c757d;
        color: #fff;
    }

        .btn-secondary:hover {
            background: #5c636a;
        }
</style>


<div class="container">
    <div class="form-container">
        <form asp-action="Create" asp-controller="Coupon" method="post" id="couponForm" novalidate>
            @Html.AntiForgeryToken()

            <!-- Validation Summary -->
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <!-- Code Field -->
            <div class="mb-3">
                <label asp-for="Code" class="form-label" for="Code">
                    @_stringLocalizer[SharedResourcesKeys.Efreshli.Coupon.Code]
                </label>
                <input asp-for="Code" class="form-control" id="Code" placeholder="SUMMER20" minlength="4" maxlength="20" />
                <span asp-validation-for="Code" class="text-danger"></span>
            </div>

            <!-- Discount Value Field -->
            <div class="mb-3">
                <label asp-for="DiscountValue" class="form-label" for="DiscountValue">
                    @_stringLocalizer[SharedResourcesKeys.Efreshli.Coupon.DiscountValue]
                </label>
                <div class="input-group">
                    <input asp-for="DiscountValue" class="form-control" id="DiscountValue" placeholder="10" type="number" min="0" step="0.01" />
                    <span class="input-group-text" id="discountSuffix" data-currency="@_stringLocalizer[SharedResourcesKeys.Currency.EGP]">$</span>
                </div>
                <span asp-validation-for="DiscountValue" class="text-danger"></span>
            </div>

            <!-- Discount Type Toggle -->
            <div class="mb-3">
                <input type="radio" asp-for="IsPercentage" id="fixedAmount" value="false" checked="@(!Model.IsPercentage)" />
                <label class="btn-toggle" for="fixedAmount">
                    @_stringLocalizer[SharedResourcesKeys.Efreshli.Coupon.FixedAmount]
                </label>

                <input type="radio" asp-for="IsPercentage" id="percentage" value="true" checked="@(Model.IsPercentage)" />
                <label class="btn-toggle" for="percentage">
                    @_stringLocalizer[SharedResourcesKeys.Efreshli.Coupon.IsPercentage]
                </label>
            </div>

            <!-- Usage Limit -->
            <div class="mb-3">
                <label asp-for="UsageLimit" class="form-label" for="UsageLimit">
                    @_stringLocalizer[SharedResourcesKeys.Efreshli.Coupon.UsageLimit]
                </label>
                <input asp-for="UsageLimit" class="form-control" id="UsageLimit" type="number" min="0" placeholder="0 for unlimited" />
                <span asp-validation-for="UsageLimit" class="text-danger"></span>
            </div>

            <!-- Actions -->
            <div class="form-actions">
                <button type="reset" class="btn btn-secondary">
                    @_stringLocalizer[SharedResourcesKeys.Actions.Reset]
                </button>
                <button type="submit" class="btn btn-primary">
                    @_stringLocalizer[SharedResourcesKeys.Actions.Create]
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const form = document.getElementById('couponForm');
            const discountSuffix = document.getElementById('discountSuffix');
            const discountValueInput = document.getElementById('DiscountValue');

            const updateDisplay = () => {
                const isPercentage = form.querySelector('input[name="IsPercentage"]:checked').value === 'true';
                discountSuffix.textContent = isPercentage ? '%' : discountSuffix.dataset.currency;

                if (isPercentage) {
                    discountValueInput.placeholder = 'e.g., 20 (for 20%)';
                    discountValueInput.max = 100;
                } else {
                    discountValueInput.placeholder = 'e.g., 10';
                    discountValueInput.removeAttribute('max');
                }
            };

            document.getElementById('Code').addEventListener('input', function() {
                this.value = this.value.toUpperCase();
            });

            form.querySelectorAll('input[name="IsPercentage"]').forEach(radio => {
                radio.addEventListener('change', updateDisplay);
            });

            updateDisplay();
        });
    </script>
}
