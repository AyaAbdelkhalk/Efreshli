@model Efreshli.MVC.Models.BrandDisplayViewModel

@{
    ViewData["Title"] = "Brand Details";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">Brand Details</h3>
                    <div class="card-tools">
                        <button type="button" class="btn btn-success btn-sm" onclick="printDetails()">
                            <i class="fas fa-print"></i> Print
                        </button>
                        <button type="button" class="btn btn-info btn-sm" onclick="shareBrand()">
                            <i class="fas fa-share"></i> Share
                        </button>
                        <a asp-action="Index" class="btn btn-secondary btn-sm">
                            <i class="fas fa-arrow-left"></i> Back to List
                        </a>
                    </div>
                </div>

                <div class="card-body">
                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            @TempData["Error"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    <div class="row">
                        <div class="col-md-8">
                            <!-- Basic Information -->
                            <div class="card mb-3">
                                <div class="card-header">
                                    <h5 class="card-title mb-0">
                                        <i class="fas fa-info-circle"></i> Basic Information
                                    </h5>
                                </div>
                                <div class="card-body">
                                    <div class="row mb-3">
                                        <div class="col-sm-4">
                                            <strong>ID:</strong>
                                        </div>
                                        <div class="col-sm-8">
                                            <span class="badge bg-primary">@Model.BrandId</span>
                                        </div>
                                    </div>

                                    <div class="row mb-3">
                                        <div class="col-sm-4">
                                            <strong>Arabic Name:</strong>
                                        </div>
                                        <div class="col-sm-8">
                                            <h5 class="text-primary">@Model.NameAr</h5>
                                        </div>
                                    </div>

                                    <div class="row mb-3">
                                        <div class="col-sm-4">
                                            <strong>English Name:</strong>
                                        </div>
                                        <div class="col-sm-8">
                                            <h5 class="text-info">@Model.NameEn</h5>
                                        </div>
                                    </div>

                                    @if (Model.CreatedDate.HasValue)
                                    {
                                        <div class="row mb-3">
                                            <div class="col-sm-4">
                                                <strong>Created Date:</strong>
                                            </div>
                                            <div class="col-sm-8">
                                                <span class="text-muted">
                                                    <i class="fas fa-calendar-alt"></i>
                                                    @Model.CreatedDate.Value.ToString("yyyy-MM-dd HH:mm")
                                                </span>
                                            </div>
                                        </div>
                                    }

                                    @if (Model.UpdatedDate.HasValue)
                                    {
                                        <div class="row mb-3">
                                            <div class="col-sm-4">
                                                <strong>Last Updated:</strong>
                                            </div>
                                            <div class="col-sm-8">
                                                <span class="text-muted">
                                                    <i class="fas fa-edit"></i>
                                                    @Model.UpdatedDate.Value.ToString("yyyy-MM-dd HH:mm")
                                                </span>
                                            </div>
                                        </div>
                                    }

                                    <div class="row mb-3">
                                        <div class="col-sm-4">
                                            <strong>Image Status:</strong>
                                        </div>
                                        <div class="col-sm-8">
                                            @if (Model.ImageId.HasValue)
                                            {
                                                <span class="badge bg-success">
                                                    <i class="fas fa-check-circle"></i> Available
                                                </span>
                                                <small class="text-muted ms-2">Image ID: @Model.ImageId.Value</small>
                                            }
                                            else
                                            {
                                                <span class="badge bg-warning">
                                                    <i class="fas fa-exclamation-triangle"></i> Not Available
                                                </span>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Related Information -->
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="card">
                                        <div class="card-header">
                                            <h6 class="card-title mb-0">
                                                <i class="fas fa-chart-bar"></i> Statistics
                                            </h6>
                                        </div>
                                        <div class="card-body">
                                            <div class="row text-center">
                                                <div class="col-6">
                                                    <div class="border rounded p-2">
                                                        <h4 class="text-primary mb-0">0</h4>
                                                        <small class="text-muted">Products</small>
                                                    </div>
                                                </div>
                                                <div class="col-6">
                                                    <div class="border rounded p-2">
                                                        <h4 class="text-success mb-0">0</h4>
                                                        <small class="text-muted">Active</small>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="card">
                                        <div class="card-header">
                                            <h6 class="card-title mb-0">
                                                <i class="fas fa-clock"></i> Activity
                                            </h6>
                                        </div>
                                        <div class="card-body">
                                            <div class="timeline">
                                                <div class="timeline-item">
                                                    <small class="text-muted">@DateTime.Now.ToString("MMM dd, yyyy")</small>
                                                    <p class="mb-0">Brand details viewed</p>
                                                </div>
                                                @if (Model.UpdatedDate.HasValue)
                                                {
                                                    <div class="timeline-item">
                                                        <small class="text-muted">@Model.UpdatedDate.Value.ToString("MMM dd, yyyy")</small>
                                                        <p class="mb-0">Brand updated</p>
                                                    </div>
                                                }
                                                @if (Model.CreatedDate.HasValue)
                                                {
                                                    <div class="timeline-item">
                                                        <small class="text-muted">@Model.CreatedDate.Value.ToString("MMM dd, yyyy")</small>
                                                        <p class="mb-0">Brand created</p>
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-4">
                            <!-- Image Section -->
                            <div class="card mb-3">
                                <div class="card-header">
                                    <h6 class="card-title mb-0">
                                        <i class="fas fa-image"></i> Brand Image
                                    </h6>
                                </div>
                                <div class="card-body text-center">
                                    @if (Model.ImageId.HasValue)
                                    {
                                        <div class="mb-3">
                                            <div class="image-container" style="position: relative; display: inline-block;">
                                                <img id="brandImage" src="#" alt="Brand Image"
                                                     style="max-width: 100%; max-height: 200px; border-radius: 8px;" />
                                                <button type="button" class="btn btn-sm btn-light"
                                                        style="position: absolute; top: 5px; right: 5px;"
                                                        onclick="viewFullImage()">
                                                    <i class="fas fa-expand"></i>
                                                </button>
                                            </div>
                                            <p class="mt-2 mb-0 text-success">
                                                <strong>Image Available</strong>
                                            </p>
                                            <small class="text-muted">Image ID: @Model.ImageId.Value</small>
                                        </div>
                                        <div class="btn-group" role="group">
                                            <button type="button" class="btn btn-sm btn-outline-primary" onclick="downloadImage()">
                                                <i class="fas fa-download"></i> Download
                                            </button>
                                            <button type="button" class="btn btn-sm btn-outline-secondary" onclick="copyImageUrl()">
                                                <i class="fas fa-link"></i> Copy URL
                                            </button>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="mb-3">
                                            <i class="fas fa-image fa-4x text-muted"></i>
                                            <p class="mt-2 mb-0 text-muted">
                                                <strong>No Image</strong>
                                            </p>
                                            <small class="text-muted">No image has been uploaded for this brand</small>
                                        </div>
                                        <button type="button" class="btn btn-outline-primary btn-sm" onclick="uploadImage()">
                                            <i class="fas fa-upload"></i> Upload Image
                                        </button>
                                    }
                                </div>
                            </div>

                            <!-- Quick Actions -->
                            <div class="card">
                                <div class="card-header">
                                    <h6 class="card-title mb-0">
                                        <i class="fas fa-bolt"></i> Quick Actions
                                    </h6>
                                </div>
                                <div class="card-body">
                                    <div class="d-grid gap-2">
                                        <a asp-action="Edit" asp-route-id="@Model.BrandId" class="btn btn-warning btn-sm">
                                            <i class="fas fa-edit"></i> Edit Brand
                                        </a>
                                        <button type="button" class="btn btn-info btn-sm" onclick="duplicateBrand()">
                                            <i class="fas fa-copy"></i> Duplicate
                                        </button>
                                        <button type="button" class="btn btn-success btn-sm" onclick="addProduct()">
                                            <i class="fas fa-plus"></i> Add Product
                                        </button>
                                        <a asp-action="Delete" asp-route-id="@Model.BrandId" class="btn btn-danger btn-sm">
                                            <i class="fas fa-trash"></i> Delete
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card-footer">
                    <div class="d-flex justify-content-between">
                        <div>
                            <a asp-action="Edit" asp-route-id="@Model.BrandId" class="btn btn-warning">
                                <i class="fas fa-edit"></i> Edit
                            </a>
                            <a asp-action="Delete" asp-route-id="@Model.BrandId" class="btn btn-danger">
                                <i class="fas fa-trash"></i> Delete
                            </a>
                        </div>
                        <div>
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="fas fa-list"></i> View All Brands
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Full Image Modal -->
<div class="modal fade" id="fullImageModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Brand Image</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center">
                <img id="fullImage" src="#" alt="Full Brand Image" style="max-width: 100%;" />
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-primary" onclick="downloadImage()">
                    <i class="fas fa-download"></i> Download
                </button>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function printDetails() {
            window.print();
        }

        function shareBrand() {
            if (navigator.share) {
                navigator.share({
                    title: '@Model.NameEn - Brand Details',
                    text: 'Check out this brand: @Model.NameEn',
                    url: window.location.href
                });
            } else {
                // Fallback for browsers that don't support Web Share API
                navigator.clipboard.writeText(window.location.href).then(() => {
                    alert('Link copied to clipboard!');
                });
            }
        }

        function viewFullImage() {
            const image = document.getElementById('brandImage');
            const fullImage = document.getElementById('fullImage');
            fullImage.src = image.src;
            new bootstrap.Modal(document.getElementById('fullImageModal')).show();
        }

        function downloadImage() {
        @if (Model.ImageId.HasValue)
        {
            <text>
                    // This would typically make an API call to get the image URL
                    alert('Download functionality would be implemented here');
            </text>
        }
        else
        {
            <text>
                    alert('No image available to download');
            </text>
        }
        }

        function copyImageUrl() {
        @if (Model.ImageId.HasValue)
        {
            <text>
                    // This would typically get the actual image URL from an API
                    const imageUrl = 'https://example.com/images/@Model.ImageId.Value';
                    navigator.clipboard.writeText(imageUrl).then(() => {
                        alert('Image URL copied to clipboard!');
                    });
            </text>
        }
        else
        {
            <text>
                    alert('No image available');
            </text>
        }
        }

        function uploadImage() {
            // Redirect to edit page to upload image
            window.location.href = '@Url.Action("Edit", new { id = Model.BrandId })';
        }

        function duplicateBrand() {
            if (confirm('Do you want to create a copy of this brand?')) {
                // This would typically make an API call to duplicate the brand
                alert('Duplicate functionality would be implemented here');
            }
        }

        function addProduct() {
            // This would typically redirect to product creation with brand pre-selected
            alert('Add product functionality would be implemented here');
        }

        // Auto-hide alerts after 5 seconds
        setTimeout(function() {
            $('.alert').fadeOut('slow');
        }, 5000);

        // Confirmation for delete button
        $(document).ready(function() {
            $('.btn-danger').click(function(e) {
                if (!confirm('Are you sure you want to delete this brand?')) {
                    e.preventDefault();
                }
            });
        });
    </script>

    <style>
        .timeline {
            position: relative;
            padding-left: 20px;
        }

        .timeline-item {
            position: relative;
            padding-bottom: 10px;
            border-left: 2px solid #e9ecef;
            padding-left: 15px;
        }

            .timeline-item:before {
                content: '';
                position: absolute;
                left: -6px;
                top: 0;
                width: 10px;
                height: 10px;
                border-radius: 50%;
                background: #007bff;
            }

        .image-container {
            position: relative;
            display: inline-block;
        }

        @media print {
            .card-tools, .card-footer, .btn

        {
            display: none !important;
        }

        }
    </style>
}