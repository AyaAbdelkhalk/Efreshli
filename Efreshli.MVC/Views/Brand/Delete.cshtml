@model Efreshli.MVC.Models.BrandDisplayViewModel

@{
    ViewData["Title"] = "Delete Brand";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card border-danger">
                <div class="card-header bg-danger text-white">
                    <h3 class="card-title">
                        <i class="fas fa-exclamation-triangle"></i> Confirm Brand Deletion
                    </h3>
                    <div class="card-tools">
                        <a asp-action="Index" class="btn btn-light btn-sm">
                            <i class="fas fa-arrow-left"></i> Back to List
                        </a>
                    </div>
                </div>

                <div class="card-body">
                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            @TempData["Error"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    <div class="alert alert-warning" role="alert">
                        <i class="fas fa-exclamation-triangle"></i>
                        <strong>Warning:</strong> This action cannot be undone. The brand will be permanently deleted from the system.
                    </div>

                    <div class="row">
                        <div class="col-md-8">
                            <h4 class="text-danger mb-4">Are you sure you want to delete this brand?</h4>

                            <div class="row mb-3">
                                <div class="col-sm-4">
                                    <strong>ID:</strong>
                                </div>
                                <div class="col-sm-8">
                                    <span class="badge bg-primary">@Model.BrandId</span>
                                </div>
                            </div>

                            <div class="row mb-3">
                                <div class="col-sm-4">
                                    <strong>Arabic Name:</strong>
                                </div>
                                <div class="col-sm-8">
                                    <h5 class="text-primary">@Model.NameAr</h5>
                                </div>
                            </div>

                            <div class="row mb-3">
                                <div class="col-sm-4">
                                    <strong>English Name:</strong>
                                </div>
                                <div class="col-sm-8">
                                    <h5 class="text-info">@Model.NameEn</h5>
                                </div>
                            </div>

                            @if (Model.CreatedDate.HasValue)
                            {
                                <div class="row mb-3">
                                    <div class="col-sm-4">
                                        <strong>Created Date:</strong>
                                    </div>
                                    <div class="col-sm-8">
                                        <span class="text-muted">
                                            <i class="fas fa-calendar-alt"></i>
                                            @Model.CreatedDate.Value.ToString("yyyy-MM-dd HH:mm")
                                        </span>
                                    </div>
                                </div>
                            }

                            <div class="row mb-3">
                                <div class="col-sm-4">
                                    <strong>Image Status:</strong>
                                </div>
                                <div class="col-sm-8">
                                    @if (Model.ImageId.HasValue)
                                    {
                                        <span class="badge bg-success">
                                            <i class="fas fa-check-circle"></i> Available
                                        </span>
                                        <small class="text-muted ms-2">Image ID: @Model.ImageId.Value</small>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning">
                                            <i class="fas fa-exclamation-triangle"></i> Not Available
                                        </span>
                                    }
                                </div>
                            </div>
                        </div>

                        <div class="col-md-4">
                            <div class="card bg-light border-warning">
                                <div class="card-header bg-warning">
                                    <h6 class="card-title mb-0">
                                        <i class="fas fa-info-circle"></i> Additional Information
                                    </h6>
                                </div>
                                <div class="card-body">
                                    <ul class="list-unstyled mb-0">
                                        <li class="mb-2">
                                            <i class="fas fa-box text-info"></i>
                                            <strong>Products:</strong> Related products may be affected
                                        </li>
                                        <li class="mb-2">
                                            <i class="fas fa-database text-warning"></i>
                                            <strong>Data:</strong> All related data will be deleted
                                        </li>
                                        <li class="mb-2">
                                            <i class="fas fa-image text-danger"></i>
                                            <strong>Images:</strong> Related images will be deleted
                                        </li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card-footer">
                    <form asp-action="Delete" method="post" style="display: inline;">
                        <input type="hidden" asp-for="BrandId" />

                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <button type="submit" class="btn btn-danger btn-lg"
                                        onclick="return confirm('Are you absolutely sure you want to delete this brand? This action cannot be undone!')">
                                    <i class="fas fa-trash"></i> Yes, Delete Brand
                                </button>
                            </div>

                            <div>
                                <a asp-action="Details" asp-route-id="@Model.BrandId" class="btn btn-info">
                                    <i class="fas fa-eye"></i> View Details
                                </a>
                                <a asp-action="Edit" asp-route-id="@Model.BrandId" class="btn btn-warning">
                                    <i class="fas fa-edit"></i> Edit Instead of Delete
                                </a>
                                <a asp-action="Index" class="btn btn-secondary">
                                    <i class="fas fa-times"></i> Cancel
                                </a>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Auto-hide alerts after 5 seconds
        setTimeout(function() {
            $('.alert').fadeOut('slow');
        }, 5000);

        // Additional confirmation for delete
        $(document).ready(function() {
            $('form').submit(function(e) {
                const confirmed = confirm('Final confirmation: Are you sure you want to delete brand "@Model.NameAr"?\n\nThis action is final and cannot be undone!');
                if (!confirmed) {
                    e.preventDefault();
                    return false;
                }
            });
        });
    </script>
}